# Required — generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-strong-random-secret

# Bootstrap admin (only used on first run when the DB is empty)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=changeme

# Session lifetime in hours (default 12)
# SESSION_LIFETIME_HOURS=12

# File retention in days (default 90)
# RETENTION_DAYS=90

# Auth rate limit: attempts per minute per IP/username (default 5)
# RATE_LIMIT_AUTH_PER_MIN=5

# Max upload size in MB (default 10)
# MAX_UPLOAD_MB=10

# Bind mount for data instead of Docker named volume (optional)
# DATA_DIR=/opt/bidparser/data

# Trusted proxy IPs for X-Forwarded-* headers (default: trust all)
# Tighten to your reverse proxy's IP/CIDR in production.
# FORWARDED_ALLOW_IPS=*

# Public URL of the app (used for constructing absolute URLs behind a reverse proxy)
# BASE_URL=https://your-domain.com
