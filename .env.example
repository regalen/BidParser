# Required — generate with: openssl rand -hex 32
SESSION_SECRET=super_secret_string_change_this_in_production

# Bootstrap admin (only used on first run when the DB is empty)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Session lifetime in hours (default 12)
SESSION_LIFETIME_HOURS=12

# Container timezone — controls server-local time used for the Utilisation
# Dashboard's daily buckets. Defaults to Australia/Sydney if unset.
# TZ=Australia/Sydney

# File retention in days (default 90)
# RETENTION_DAYS=90

# Auth rate limit: attempts per minute per IP/username (default 5)
# RATE_LIMIT_AUTH_PER_MIN=5

# Max upload size in MB (default 10)
# MAX_UPLOAD_MB=10

# Bind mount for data instead of the default Docker named volume (optional)
# Leave unset to let Docker create/use the bidparser-data named volume.
# DATA_DIR=/opt/bidparser/data

# Required in production: trusted proxy IPs for X-Forwarded-* headers.
# Use the IP address of your reverse proxy as seen by the app container.
FORWARDED_ALLOW_IPS=127.0.0.1

# SQL Server — SA password must meet SQL Server complexity requirements
# (≥8 chars, upper + lower + digit + symbol). SQL Server refuses to start
# with a weak password and the app healthcheck will never pass.
MSSQL_SA_PASSWORD=Change_This_Strong_P@ssw0rd
MSSQL_DB=bidparser
