<Window x:Class="BidParser.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:BidParser.Wpf.Converters"
        Title="BidParser Lite"
        Icon="Assets/app.ico"
        MinWidth="820" MinHeight="560"
        Width="1020" Height="680"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>

        <!-- Field label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>

        <!-- Text input -->
        <Style x:Key="FieldTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>

        <!-- ComboBox -->
        <Style x:Key="FieldComboBox" TargetType="ComboBox">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>

        <!-- Primary button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Link-style button -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2563EB"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"
                                   TextDecorations="Underline"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small secondary button -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F9FAFB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Main content: settings rail + result pane ──────────────────── -->
        <Grid Grid.Row="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Left rail: settings ─────────────────────────────────────────── -->
        <Border Grid.Column="0"
                Background="#FFFFFF"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,24,20,20" IsEnabled="{Binding IsNotRunning}">

                    <!-- App title -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Image Source="Assets/logo.png" Width="28" Height="28"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="BidParser Lite"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#111827" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Quote → Parsed XLSX"
                               FontSize="11" Foreground="#9CA3AF" Margin="0,0,0,24"/>

                    <!-- Vendor -->
                    <TextBlock Text="Vendor" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Vendors}"
                              SelectedItem="{Binding SelectedVendor}"
                              Style="{StaticResource FieldComboBox}"/>

                    <!-- File Type -->
                    <TextBlock Text="File Type" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Parsers}"
                              SelectedItem="{Binding SelectedParser}"
                              DisplayMemberPath="DisplayName"
                              Style="{StaticResource FieldComboBox}"/>

                    <!-- CRM Template dropdown (multi-template parsers only) -->
                    <StackPanel Visibility="{Binding ShowTemplateDropdown, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="CRM Template" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding Templates}"
                                  SelectedItem="{Binding SelectedTemplate}"
                                  Style="{StaticResource FieldComboBox}"/>
                    </StackPanel>

                    <!-- FX Rate -->
                    <StackPanel Visibility="{Binding ShowFxRate, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="FX Rate *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FxRate, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldTextBox}"/>
                    </StackPanel>

                    <!-- Uplift -->
                    <StackPanel Visibility="{Binding ShowMargin, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Uplift % *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Margin, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldTextBox}"/>
                    </StackPanel>

                    <!-- Discount Off MSRP (IM%) -->
                    <StackPanel Visibility="{Binding ShowImPercent, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Discount Off MSRP % *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding ImPercent, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldTextBox}"/>
                    </StackPanel>

                    <!-- On Cost % -->
                    <StackPanel Visibility="{Binding ShowOnCostPercent, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="On Cost % (optional)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding OnCostPercent, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldTextBox}"/>
                    </StackPanel>

                    <!-- CRM template chip (read-only) -->
                    <Border Visibility="{Binding HasCrmTemplate, Converter={StaticResource BoolToVis}}"
                            Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                            CornerRadius="4" Padding="8,5" Margin="0,14,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Template: " Foreground="#1E40AF" FontSize="11"/>
                            <TextBlock Text="{Binding CrmTemplateDisplay}" Foreground="#1E40AF"
                                       FontSize="11" FontWeight="Medium"/>
                        </StackPanel>
                    </Border>

                    <!-- Convert button -->
                    <Button Content="Convert"
                            Command="{Binding ConvertCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,16,0,0"/>

                    <!-- Reset to defaults -->
                    <Button Content="Reset"
                            Command="{Binding ResetCommand}"
                            Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Stretch"
                            Margin="0,8,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ── Right pane: file + result ──────────────────────────────────── -->
        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- File drop zone -->
            <Border Grid.Row="0"
                    x:Name="DropZone"
                    BorderBrush="#D1D5DB" BorderThickness="2" CornerRadius="8"
                    Background="White" MinHeight="110"
                    AllowDrop="True"
                    Drop="DropZone_Drop"
                    DragOver="DropZone_DragOver">
                <Grid Margin="20,16">
                    <!-- Empty state -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding HasInputFile, Converter={StaticResource InvBoolToVis}}">
                        <TextBlock Text="Drop a file here, or"
                                   HorizontalAlignment="Center"
                                   Foreground="#6B7280" FontSize="13"/>
                        <Button Content="Browse…"
                                Click="Browse_Click"
                                Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Center"
                                Margin="0,4,0,0"/>
                        <TextBlock Text="PDF, XLSX, XLS  ·  max 10 MB"
                                   HorizontalAlignment="Center"
                                   Foreground="#9CA3AF" FontSize="11"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- File selected state -->
                    <Grid Visibility="{Binding HasInputFile, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding InputFileName}"
                                       FontSize="14" FontWeight="Medium"
                                       Foreground="#111827"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding InputFileSizeDisplay}"
                                       Foreground="#6B7280" FontSize="11"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Change"
                                Click="Browse_Click"
                                Style="{StaticResource LinkButton}"
                                VerticalAlignment="Center"
                                Margin="16,0,0,0"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Result panel -->
            <Grid Grid.Row="1" Margin="0,16,0,0">

                <!-- Idle -->
                <TextBlock Text="Select a file and click Convert to begin."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#9CA3AF" FontSize="13"
                           Visibility="{Binding IsIdle, Converter={StaticResource BoolToVis}}"/>

                <!-- Running -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                 Foreground="#2563EB" Background="#E5E7EB"
                                 BorderThickness="0"/>
                    <TextBlock Text="Converting…" Foreground="#6B7280" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- Success -->
                <Border CornerRadius="8" Background="#F0FDF4"
                        BorderBrush="#86EFAC" BorderThickness="1"
                        Padding="20" VerticalAlignment="Top"
                        Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="✓  Converted successfully"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#15803D" Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Computed" Foreground="#374151" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="{Binding ResultComputedTotal}"
                                       Foreground="#111827" FontSize="12" FontWeight="Medium"
                                       Margin="6,0,16,0"/>
                            <TextBlock Grid.Column="2" Text="Quoted" Foreground="#374151" FontSize="12"/>
                            <TextBlock Grid.Column="3" Text="{Binding ResultQuotedTotal}"
                                       Foreground="#111827" FontSize="12" FontWeight="Medium"
                                       Margin="6,0,16,0"/>
                            <TextBlock Grid.Column="4" Text="✓ Match" Foreground="#16A34A"
                                       FontSize="12" FontWeight="Medium"
                                       Visibility="{Binding ResultTotalsMatch, Converter={StaticResource BoolToVis}}"/>
                        </Grid>

                        <Separator Background="#BBF7D0" Margin="0,12"/>

                        <TextBlock Foreground="#374151" FontSize="12" Margin="0,0,0,8">
                            <Run Text="Saved to  "/>
                            <Run Text="{Binding ResultOutputPath, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="#111827"/>
                        </TextBlock>

                        <!-- Report-type guidance (hardcoded per file type) -->
                        <Border CornerRadius="6" Background="#F0F9FF" BorderBrush="#BAE6FD" BorderThickness="1"
                                Padding="12,8" Margin="0,0,0,12"
                                Visibility="{Binding HasResultReportType, Converter={StaticResource BoolToVis}}">
                            <TextBlock TextWrapping="Wrap" Foreground="#374151" FontSize="12">
                                <Run Text="When sending this quote to the customer, use the "/>
                                <Run Text="{Binding ResultReportType, Mode=OneWay}" FontWeight="SemiBold" Foreground="#0C4A6E"/>
                                <Run Text=" report type."/>
                            </TextBlock>
                        </Border>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Open Folder" Command="{Binding OpenFolderCommand}"
                                    Style="{StaticResource SecondaryButton}"/>
                            <Button Content="Open File" Command="{Binding OpenFileCommand}"
                                    Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Warning (mismatch or cancelled lines) -->
                <Border CornerRadius="8" Background="#FFFBEB"
                        BorderBrush="#FCD34D" BorderThickness="1"
                        Padding="20" VerticalAlignment="Top"
                        Visibility="{Binding IsWarning, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="⚠  Converted with warnings"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#92400E" Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Computed" Foreground="#374151" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="{Binding ResultComputedTotal}"
                                       Foreground="#111827" FontSize="12" FontWeight="Medium"
                                       Margin="6,0,16,0"/>
                            <TextBlock Grid.Column="2" Text="Quoted" Foreground="#374151" FontSize="12"/>
                            <TextBlock Grid.Column="3" Text="{Binding ResultQuotedTotal}"
                                       Foreground="#111827" FontSize="12" FontWeight="Medium"
                                       Margin="6,0,16,0"/>
                            <StackPanel Grid.Column="4" Orientation="Horizontal"
                                        Visibility="{Binding ResultTotalsMatch, Converter={StaticResource InvBoolToVis}}">
                                <TextBlock Text="✗ Mismatch " Foreground="#B45309"
                                           FontSize="12" FontWeight="Medium"/>
                                <TextBlock Text="{Binding ResultDifference}" Foreground="#B45309"
                                           FontSize="12"/>
                            </StackPanel>
                        </Grid>

                        <!-- Cancelled lines -->
                        <StackPanel Visibility="{Binding HasCancelledLines, Converter={StaticResource BoolToVis}}"
                                    Margin="0,10,0,0">
                            <TextBlock Text="Cancelled lines:" Foreground="#92400E"
                                       FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                            <ItemsControl ItemsSource="{Binding CancelledLinesDisplay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="#78350F"
                                                   FontSize="12" Margin="0,1"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <Separator Background="#FDE68A" Margin="0,12"/>

                        <TextBlock Foreground="#374151" FontSize="12" Margin="0,0,0,8">
                            <Run Text="Saved to  "/>
                            <Run Text="{Binding ResultOutputPath, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="#111827"/>
                        </TextBlock>

                        <!-- Report-type guidance (hardcoded per file type) -->
                        <Border CornerRadius="6" Background="#F0F9FF" BorderBrush="#BAE6FD" BorderThickness="1"
                                Padding="12,8" Margin="0,0,0,12"
                                Visibility="{Binding HasResultReportType, Converter={StaticResource BoolToVis}}">
                            <TextBlock TextWrapping="Wrap" Foreground="#374151" FontSize="12">
                                <Run Text="When sending this quote to the customer, use the "/>
                                <Run Text="{Binding ResultReportType, Mode=OneWay}" FontWeight="SemiBold" Foreground="#0C4A6E"/>
                                <Run Text=" report type."/>
                            </TextBlock>
                        </Border>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Open Folder" Command="{Binding OpenFolderCommand}"
                                    Style="{StaticResource SecondaryButton}"/>
                            <Button Content="Open File" Command="{Binding OpenFileCommand}"
                                    Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Error -->
                <Border CornerRadius="8" Background="#FEF2F2"
                        BorderBrush="#FCA5A5" BorderThickness="1"
                        Padding="20" VerticalAlignment="Top"
                        Visibility="{Binding IsError, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock FontSize="15" FontWeight="SemiBold"
                                   Foreground="#991B1B" Margin="0,0,0,10">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="✗  Conversion failed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ErrorStage}" Value="file_type">
                                            <Setter Property="Text" Value="✗  Wrong file type"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ErrorStage}" Value="currency">
                                            <Setter Property="Text" Value="✗  Unsupported currency"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ErrorStage}" Value="upload">
                                            <Setter Property="Text" Value="✗  Invalid file"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#7F1D1D" FontSize="13"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Grid>
        </Grid>

        <!-- ── Footer: version · GitHub · copyright ────────────────────────── -->
        <Border Grid.Row="1" Background="#FFFFFF"
                BorderBrush="#E5E7EB" BorderThickness="0,1,0,0"
                Padding="20,8">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="BidParser" Foreground="#6B7280" FontSize="11" FontWeight="Medium"/>
                    <TextBlock Text="{Binding AppVersionDisplay}" Foreground="#6B7280" FontSize="11" Margin="6,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="GitHub" Command="{Binding OpenReleasesCommand}"
                            Style="{StaticResource LinkButton}" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CopyrightText}" Foreground="#9CA3AF" FontSize="11"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
